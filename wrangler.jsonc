{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "clinebox-kanban13",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-26",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "binding": "ASSETS",
    "directory": "./public",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },

  "vars": {
    "APP_NAME": "Cline Kanban",
    "ENVIRONMENT": "production"
  },

  "containers": [
    {
      "class_name": "KanbanService",
      "image": "./Dockerfile",
      "instance_type": {
        "vcpu": 2,
        "memory_mib": 4096,
        "disk_mb": 20480
      }
    }
  ],

  "durable_objects": {
    "bindings": [
      {
        "name": "KANBAN_SERVICE",
        "class_name": "KanbanService"
      }
    ]
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["KanbanService"]
    }
  ],

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "clinebox-kanban-db",
      "database_id": "d6cee9db-1244-4783-a5ab-ad723e12629a"
    }
  ],

  "kv_namespaces": [
    {
      "binding": "KANBAN_KV",
      "id": "56183057824649b4a3b19b69a4faa471"
    }
  ]
}
